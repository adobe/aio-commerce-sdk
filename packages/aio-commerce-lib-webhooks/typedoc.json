{
  "$schema": "https://typedoc-plugin-markdown.org/schema.json",
  "extends": ["@aio-commerce-sdk/config-typedoc/typedoc.base.json"],

  "entryPoints": ["./source/api/index.ts", "./source/responses/index.ts"],
  "out": "docs/api-reference",

  "validation": {
    "notExported": false
  },

  "externalSymbolLinkMappings": {
    "@adobe/aio-commerce-lib-api": {
      "AdobeCommerceHttpClient": "https://github.com/adobe/aio-commerce-sdk/blob/main/packages/aio-commerce-lib-api/docs/api-reference/index/classes/AdobeCommerceHttpClient.md",
      "AdobeIoEventsHttpClient": "https://github.com/adobe/aio-commerce-sdk/blob/main/packages/aio-commerce-lib-api/docs/api-reference/index/classes/AdobeIoEventsHttpClient.md",
      "ApiClient": "https://github.com/adobe/aio-commerce-sdk/blob/main/packages/aio-commerce-lib-api/docs/api-reference/index/classes/ApiClient.md",
      "ApiFunction": "https://github.com/adobe/aio-commerce-sdk/blob/main/packages/aio-commerce-lib-api/docs/api-reference/index/type-aliases/ApiFunction.md",
      "CommerceHttpClientParams": "https://github.com/adobe/aio-commerce-sdk/blob/main/packages/aio-commerce-lib-api/docs/api-reference/index/type-aliases/CommerceHttpClientParams.md"
    },

    "@adobe/aio-commerce-lib-core": {
      "CommerceSdkValidationError": "https://github.com/adobe/aio-commerce-sdk/blob/main/packages/aio-commerce-lib-core/docs/api-reference/error/classes/CommerceSdkValidationError.md"
    },

    "ky": {
      "Options": "https://github.com/sindresorhus/ky?tab=readme-ov-file#options",
      "HTTPError": "https://github.com/sindresorhus/ky?tab=readme-ov-file#httperror"
    }
  }
}
