{
  "$schema": "https://typedoc-plugin-markdown.org/schema.json",
  "extends": ["@aio-commerce-sdk/config-typedoc/typedoc.base.json"],

  "entryPoints": [
    "./source/index.ts",
    "./source/grid-columns/index.ts",
    "./source/mass-actions/index.ts",
    "./source/menu/index.ts",
    "./source/order-view-buttons/index.ts",
    "./source/web/index.ts"
  ],
  "out": "docs/api-reference",

  "validation": {
    "notExported": false
  },

  "externalSymbolLinkMappings": {
    "@adobe/aio-commerce-lib-api": {
      "AdobeCommerceHttpClient": "https://github.com/adobe/aio-commerce-sdk/blob/main/packages/aio-commerce-lib-api/docs/api-reference/classes/AdobeCommerceHttpClient.md"
    },

    "ky": {
      "Options": "https://github.com/sindresorhus/ky?tab=readme-ov-file#options"
    }
  }
}
